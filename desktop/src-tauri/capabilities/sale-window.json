{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sale-window",
  "description": "Restricted capabilities for sale windows (no window creation, no secure storage)",
  "windows": ["pos-sale-*"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:resources:default",
    "core:window:default",
    "core:window:allow-destroy",
    "core:webview:default",
    "log:default",
    "log:allow-log",
    "sql:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close"
  ]
}
