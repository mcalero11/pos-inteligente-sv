{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Full capabilities for the main POS window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:resources:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-destroy",
    "core:webview:default",
    "opener:default",
    "log:default",
    "log:allow-log",
    "shell:allow-open",
    "stronghold:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close"
  ]
}
